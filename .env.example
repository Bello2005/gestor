APP_NAME="Sistema de Gestión"
APP_ENV=production
APP_KEY=YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://gestor-0o3w.onrender.com

# Database Configuration for Supabase
DB_CONNECTION=pgsql
DB_HOST=db.awkhfsuhrpojljdxblz.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=YOUR_DB_PASSWORD

# Supabase Pooler URL (for connection pooling)
DATABASE_URL=postgresql://postgres.awkhnfsuhrpojljdxblz:YOUR_DB_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Session Configuration
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=gestor-0o3w.onrender.com
SESSION_SAME_SITE=lax

# Performance and Storage
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
pool_mode=transaction

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error

# Broadcasting and Mail
BROADCAST_DRIVER=log
MAIL_MAILER=log

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
