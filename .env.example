APP_NAME="Sistema de Gestión"
APP_ENV=production
APP_KEY=YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://gestor-0o3w.onrender.com

# Database Configuration for Supabase
DB_CONNECTION=pgsql
DB_HOST=db.awkhfsuhrpojljdxblz.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=YOUR_DB_PASSWORD

# Supabase Pooler URL (for connection pooling)
DATABASE_URL=postgresql://postgres.awkhnfsuhrpojljdxblz:YOUR_DB_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Session Configuration
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=gestor-0o3w.onrender.com
SESSION_SAME_SITE=lax

# Performance and Storage
CACHE_DRIVER=file
FILESYSTEM_DISK=public

# Queue Configuration
# Usar 'database' para enviar correos en segundo plano (evita timeouts)
# Requiere correr: php artisan queue:work en background
QUEUE_CONNECTION=database

pool_mode=transaction

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error

# Broadcasting and Mail
BROADCAST_DRIVER=log

# Mail Configuration
# Para producción, usa 'resend' (gratis hasta 3000 emails/mes)
# Para desarrollo local, usa 'log' para ver emails en logs
MAIL_MAILER=resend

# Configuración de Resend (https://resend.com)
# 1. Regístrate en https://resend.com/signup
# 2. Obtén tu API Key en https://resend.com/api-keys
# 3. Usa onboarding@resend.dev como remitente (sin verificar dominio)
#    O verifica tu dominio para usar tu propio email
RESEND_KEY=tu_api_key_de_resend_aqui

# Email del remitente (usa onboarding@resend.dev para pruebas)
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Configuración alternativa SMTP (si prefieres usar Gmail u otro)
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudinary Configuration (para subir evidencias de proyectos)
# Opción 1: URL completa (RECOMENDADA - más simple en Render)
CLOUDINARY_URL=cloudinary://645296627213276:NSI5b1UQep3bIAI8Rv9DVv85FZM@dzfpu17ur

# Opción 2: Variables individuales (el sistema las usará si no existe CLOUDINARY_URL)
CLOUDINARY_API_KEY=645296627213276
CLOUDINARY_API_SECRET=NSI5b1UQep3bIAI8Rv9DVv85FZM
CLOUDINARY_CLOUD_NAME=dzfpu17ur

VITE_APP_NAME="${APP_NAME}"
