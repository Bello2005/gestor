use Illuminate\Support\Facades\Auth;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Log;

class ProyectoController extends Controller
{
    public function index()
    {
        $order = request('order', 'desc');
        $proyectos = Proyecto::orderBy('created_at', $order)->get();
        return view('proyectos.index', compact('proyectos'));
    }

    public function create()
    {
        return view('proyectos.create');
    }

    public function store(Request $request)
    {
            $request->validate([
                'nombre_del_proyecto' => 'required|string|max:255',
                'objeto_contractual' => 'nullable|string|max:255',
                'lineas_de_accion' => 'nullable|string',
                'cobertura' => 'nullable|string|max:255',
                'entidad_contratante' => 'nullable|string|max:255',
                'fecha_de_ejecucion' => 'nullable|date',
                'plazo' => 'nullable|numeric|min:0',
                'valor_total' => 'nullable|numeric|min:0',
                'archivo_proyecto' => ['nullable','file','mimes:pdf,doc,docx,xlsx,xls','max:10240'],
                'archivo_contrato' => ['nullable','file','mimes:pdf,doc,docx','max:10240'],
                'evidencias.*' => ['nullable','file','mimes:pdf,doc,docx,jpg,jpeg,png','max:10240'],
            ], [
                'nombre_del_proyecto.required' => 'El nombre del proyecto es obligatorio.',
                'archivo_proyecto.max' => 'El archivo del proyecto no debe ser mayor a 10MB.',
                'archivo_proyecto.mimes' => 'El archivo del proyecto debe ser de tipo: PDF, DOC, DOCX, XLSX o XLS.',
                'archivo_contrato.max' => 'El contrato no debe ser mayor a 10MB.',
                'archivo_contrato.mimes' => 'El contrato debe ser de tipo: PDF, DOC o DOCX.',
                'evidencias.*.max' => 'Cada evidencia no debe ser mayor a 10MB.',
                'evidencias.*.mimes' => 'Las evidencias deben ser de tipo: PDF, DOC, DOCX, JPG, JPEG o PNG.',
            ]);

            // Establecer contexto de auditoría antes de la operación
            if (Auth::check()) {
                DB::statement("CALL set_audit_context(?, ?, ?, ?)", [
                    Auth::id(),
                    request()->ip(),
                    Auth::user()->name,
                    Auth::user()->email
                ]);
            }

            $data = $request->except(['archivo_proyecto', 'archivo_contrato', 'evidencias']);

        // Manejo de archivos
        if ($request->hasFile('archivo_proyecto')) {
            $data['cargar_archivo_proyecto'] = $request->file('archivo_proyecto')->store('proyectos/archivos', 'public');
        }

        if ($request->hasFile('archivo_contrato')) {
            $data['cargar_contrato_o_convenio'] = $request->file('archivo_contrato')->store('proyectos/contratos', 'public');
        }

        if ($request->hasFile('evidencias')) {
            $evidencias = [];
            foreach ($request->file('evidencias') as $evidencia) {
                $evidencias[] = $evidencia->store('proyectos/evidencias', 'public');
            }
            $data['cargar_evidencias'] = $evidencias;
        }

        Proyecto::create($data);

        return redirect()->route('proyectos.index')->with('success', 'Proyecto creado exitosamente.');
    }

    public function show(Proyecto $proyecto)
    {
        return view('proyectos.show', compact('proyecto'));
    }

    public function edit(Proyecto $proyecto)
    {
        return view('proyectos.edit', compact('proyecto'));
    }

    public function update(Request $request, Proyecto $proyecto)
    {
        DB::beginTransaction();
        try {
            // Log inicial super detallado
            \Log::channel('daily')->info('Iniciando actualización de proyecto', [
                'proyecto_id' => $proyecto->id,
                'request_data' => $request->all(),
                'method' => $request->method(),
                'url' => $request->url(),
                'estado_actual' => $proyecto->getAttributes(),
                'has_files' => $request->hasFile('archivo_proyecto') || $request->hasFile('archivo_contrato') || $request->hasFile('evidencias'),
                'input_details' => [
                    'nombre' => $request->input('nombre_del_proyecto'),
                    'objeto' => $request->input('objeto_contractual'),
                    'estado' => $request->input('estado'),
                    'valor' => $request->input('valor_total'),
                ]
            ]);

            // Establecer contexto de auditoría antes de la operación
            if (Auth::check()) {
                DB::statement("CALL set_audit_context(?, ?, ?, ?)", [
                    Auth::id(),
                    request()->ip(),
                    Auth::user()->name,
                    Auth::user()->email
                ]);
            }
            // Validaciones
            $request->validate([
                'nombre_del_proyecto' => 'required|string|max:255',
                'objeto_contractual' => 'nullable|string|max:255',
                'lineas_de_accion' => 'nullable|string',
                'cobertura' => 'nullable|string|max:255',
                'entidad_contratante' => 'nullable|string|max:255',
                'fecha_de_ejecucion' => 'nullable|date',
                'plazo' => 'nullable|numeric|min:0',
                'valor_total' => 'nullable|numeric|min:0',
                'archivo_proyecto' => [
                    'nullable',
                    'file',
                    'mimes:pdf,doc,docx,xlsx,xls',
                    'max:10240', // 10MB
                ],
                'archivo_contrato' => [
                    'nullable',
                    'file',
                    'mimes:pdf,doc,docx',
                    'max:10240', // 10MB
                ],
                'evidencias.*' => [
                    'nullable',
                    'file',
                    'mimes:pdf,doc,docx,jpg,jpeg,png',
                    'max:10240', // 10MB
                ],
            ], [
                'nombre_del_proyecto.required' => 'El nombre del proyecto es obligatorio.',
                'archivo_proyecto.max' => 'El archivo del proyecto no debe ser mayor a 10MB.',
                'archivo_proyecto.mimes' => 'El archivo del proyecto debe ser de tipo: PDF, DOC, DOCX, XLSX o XLS.',
                'archivo_contrato.max' => 'El contrato no debe ser mayor a 10MB.',
                'archivo_contrato.mimes' => 'El contrato debe ser de tipo: PDF, DOC o DOCX.',
                'evidencias.*.max' => 'Cada evidencia no debe ser mayor a 10MB.',
                'evidencias.*.mimes' => 'Las evidencias deben ser de tipo: PDF, DOC, DOCX, JPG, JPEG o PNG.',
            ]);

        $data = $request->only([
            'nombre_del_proyecto',
            'objeto_contractual',
            'lineas_de_accion',
            'cobertura',
            'entidad_contratante',
            'fecha_de_ejecucion',
            'plazo',
            'valor_total',
            'estado'
        ]);

        // Log de los datos que se van a actualizar
        Log::info('Datos a actualizar:', $data);

            // Manejo de archivos
            if ($request->hasFile('archivo_proyecto')) {
                try {
                    if ($proyecto->cargar_archivo_proyecto) {
                        Storage::disk('public')->delete($proyecto->cargar_archivo_proyecto);
                    }
                    $data['cargar_archivo_proyecto'] = $request->file('archivo_proyecto')->store('proyectos/archivos', 'public');
                } catch (\Exception $e) {
                    return redirect()->back()->withInput()
                        ->withErrors(['archivo_proyecto' => 'Error al cargar el archivo del proyecto: ' . $e->getMessage()]);
                }
            }

            if ($request->hasFile('archivo_contrato')) {
                try {
                    if ($proyecto->cargar_contrato_o_convenio) {
                        Storage::disk('public')->delete($proyecto->cargar_contrato_o_convenio);
                    }
                    $data['cargar_contrato_o_convenio'] = $request->file('archivo_contrato')->store('proyectos/contratos', 'public');
                } catch (\Exception $e) {
                    return redirect()->back()->withInput()
                        ->withErrors(['archivo_contrato' => 'Error al cargar el contrato: ' . $e->getMessage()]);
                }
            }

            if ($request->hasFile('evidencias')) {
                try {
                    // Eliminar evidencias anteriores
                    if ($proyecto->cargar_evidencias && is_array($proyecto->cargar_evidencias)) {
                        foreach ($proyecto->cargar_evidencias as $evidencia) {
                            Storage::disk('public')->delete($evidencia);
                        }
                    }
                    
                    $evidencias = [];
                    foreach ($request->file('evidencias') as $evidencia) {
                        $evidencias[] = $evidencia->store('proyectos/evidencias', 'public');
                    }
                    $data['cargar_evidencias'] = $evidencias;
                } catch (\Exception $e) {
                    return redirect()->back()->withInput()
                        ->withErrors(['evidencias' => 'Error al cargar las evidencias: ' . $e->getMessage()]);
                }
            }

            Log::info('Actualizando proyecto con datos:', ['data' => $data]);
            
            $proyecto->update($data);
            
            Log::info('Proyecto actualizado exitosamente', ['proyecto_id' => $proyecto->id]);

            return redirect()->route('proyectos.index')
                ->with('success', 'Proyecto actualizado exitosamente.');

        } catch (\Exception $e) {
            return redirect()->back()->withInput()
                ->withErrors(['error' => 'Error al actualizar el proyecto: ' . $e->getMessage()]);
        }
    }

    public function destroy(Proyecto $proyecto)
    {
        // Eliminar archivos asociados
        if ($proyecto->cargar_archivo_proyecto) {
            Storage::disk('public')->delete($proyecto->cargar_archivo_proyecto);
        }
        
        if ($proyecto->cargar_contrato_o_convenio) {
            Storage::disk('public')->delete($proyecto->cargar_contrato_o_convenio);
        }
        
        if ($proyecto->cargar_evidencias) {
            foreach ($proyecto->cargar_evidencias as $evidencia) {
                Storage::disk('public')->delete($evidencia);
            }
        }

        $proyecto->delete();

        return redirect()->route('proyectos.index')->with('success', 'Proyecto eliminado exitosamente.');
    }

    public function deleteProyectoArchivo(Proyecto $proyecto)
    {
        if ($proyecto->cargar_archivo_proyecto) {
            Storage::disk('public')->delete($proyecto->cargar_archivo_proyecto);
            $proyecto->cargar_archivo_proyecto = null;
            $proyecto->save();
            return redirect()->back()->with('success', 'Archivo del proyecto eliminado exitosamente.');
        }
        return redirect()->back()->with('error', 'No se encontró el archivo.');
    }

    public function deleteContratoArchivo(Proyecto $proyecto)
    {
        if ($proyecto->cargar_contrato_o_convenio) {
            Storage::disk('public')->delete($proyecto->cargar_contrato_o_convenio);
            $proyecto->cargar_contrato_o_convenio = null;
            $proyecto->save();
            return redirect()->back()->with('success', 'Contrato eliminado exitosamente.');
        }
        return redirect()->back()->with('error', 'No se encontró el archivo.');
    }

    public function deleteEvidencia(Proyecto $proyecto, $index)
    {
        if ($proyecto->cargar_evidencias && isset($proyecto->cargar_evidencias[$index])) {
            $evidencias = $proyecto->cargar_evidencias;
            $evidencia = $evidencias[$index];
            Storage::disk('public')->delete($evidencia);
            unset($evidencias[$index]);
            $proyecto->cargar_evidencias = array_values($evidencias);
            $proyecto->save();
            return redirect()->back()->with('success', 'Evidencia eliminada exitosamente.');
        }
        return redirect()->back()->with('error', 'No se encontró la evidencia.');
    }

    public function exportExcel()
    {
        $proyectos = Proyecto::all();

        $spreadsheet = new Spreadsheet();
        $sheet = $spreadsheet->getActiveSheet();

        // Encabezados
        $headers = [
            'A1' => 'NOMBRE DEL PROYECTO',
            'B1' => 'OBJETO CONTRACTUAL',
            'C1' => 'LÍNEAS DE ACCIÓN',
            'D1' => 'COBERTURA',
            'E1' => 'ENTIDAD CONTRATANTE',
            'F1' => 'FECHA DE EJECUCIÓN',
            'G1' => 'PLAZO',
            'H1' => 'VALOR TOTAL ($)',
            'I1' => 'CARGAR ARCHIVO (PROYECTO)',
            'J1' => 'CARGAR CONTRATO O CONVENIO',
            'K1' => 'CARGAR EVIDENCIAS'
        ];

        foreach ($headers as $cell => $header) {
            $sheet->setCellValue($cell, $header);
        }

        // Datos
        $row = 2;
        foreach ($proyectos as $proyecto) {
            $sheet->setCellValue('A' . $row, $proyecto->nombre_del_proyecto);
            $sheet->setCellValue('B' . $row, $proyecto->objeto_contractual);
            $sheet->setCellValue('C' . $row, $proyecto->lineas_de_accion);
            $sheet->setCellValue('D' . $row, $proyecto->cobertura);
            $sheet->setCellValue('E' . $row, $proyecto->entidad_contratante);
            $sheet->setCellValue('F' . $row, $proyecto->fecha_ejecucion_formatted);
            $sheet->setCellValue('G' . $row, $proyecto->plazo);
            $sheet->setCellValue('H' . $row, $proyecto->valor_total);
            $sheet->setCellValue('I' . $row, $proyecto->cargar_archivo_proyecto ? 'Sí' : 'No');
            $sheet->setCellValue('J' . $row, $proyecto->cargar_contrato_o_convenio ? 'Sí' : 'No');
            $sheet->setCellValue('K' . $row, $proyecto->cargar_evidencias ? count($proyecto->cargar_evidencias) . ' archivo(s)' : 'No');
            $row++;
        }

        $writer = new Xlsx($spreadsheet);
        $filename = 'proyectos_' . date('Y-m-d_H-i-s') . '.xlsx';
        $tempPath = storage_path('app/temp/' . $filename);
        
        if (!file_exists(storage_path('app/temp'))) {
            mkdir(storage_path('app/temp'), 0755, true);
        }

        $writer->save($tempPath);

        return response()->download($tempPath)->deleteFileAfterSend(true);
    }

    public function exportPdf()
    {
        $proyectos = Proyecto::all();
        
        $pdf = Pdf::loadView('proyectos.pdf', compact('proyectos'));
        $pdf->setPaper('A4', 'landscape');
        
        return $pdf->download('proyectos_' . date('Y-m-d_H-i-s') . '.pdf');
    }

    public function exportWord()
    {
        $proyectos = Proyecto::all();

        $phpWord = new PhpWord();
        $section = $phpWord->addSection([
            'orientation' => 'landscape',
            'marginTop' => 600,
            'marginBottom' => 600,
            'marginLeft' => 600,
            'marginRight' => 600,
        ]);

        // Título
        $section->addText('ESTRUCTURA DE PROYECTOS', ['bold' => true, 'size' => 16], ['alignment' => 'center']);
        $section->addTextBreak(2);

        // Tabla
        $table = $section->addTable([
            'borderSize' => 6,
            'borderColor' => '000000',
            'cellMargin' => 80
        ]);

        // Encabezados
        $table->addRow();
        $headers = ['NOMBRE DEL PROYECTO', 'OBJETO CONTRACTUAL', 'LÍNEAS DE ACCIÓN', 'COBERTURA', 'ENTIDAD CONTRATANTE', 'FECHA DE EJECUCIÓN', 'PLAZO', 'VALOR TOTAL'];
        
        foreach ($headers as $header) {
            $table->addCell(2000)->addText($header, ['bold' => true, 'size' => 8]);
        }

        // Datos
        foreach ($proyectos as $proyecto) {
            $table->addRow();
            $table->addCell(2000)->addText($proyecto->nombre_del_proyecto ?: '', ['size' => 8]);
            $table->addCell(2000)->addText($proyecto->objeto_contractual ?: '', ['size' => 8]);
            $table->addCell(2000)->addText($proyecto->lineas_de_accion ?: '', ['size' => 8]);
            $table->addCell(2000)->addText($proyecto->cobertura ?: '', ['size' => 8]);
            $table->addCell(2000)->addText($proyecto->entidad_contratante ?: '', ['size' => 8]);
            $table->addCell(2000)->addText($proyecto->fecha_ejecucion_formatted ?: '', ['size' => 8]);
            $table->addCell(2000)->addText($proyecto->plazo ?: '', ['size' => 8]);
            $table->addCell(2000)->addText($proyecto->valor_total_formatted ?: '', ['size' => 8]);
        }

        $filename = 'proyectos_' . date('Y-m-d_H-i-s') . '.docx';
        $tempPath = storage_path('app/temp/' . $filename);

        if (!file_exists(storage_path('app/temp'))) {
            mkdir(storage_path('app/temp'), 0755, true);
        }

        $objWriter = IOFactory::createWriter($phpWord, 'Word2007');
        $objWriter->save($tempPath);

        return response()->download($tempPath)->deleteFileAfterSend(true);
    }
}