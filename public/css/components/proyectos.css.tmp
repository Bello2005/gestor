/* Resetear estilos de iconos */
[class^="fa-"],
[class*=" fa-"] {
    font-family: "Font Awesome 6 Free" !important;
    font-weight: 900;
    font-style: normal;
}

/* Contenedor de iconos en la tabla */
.project-name {
    display: flex;
    align-items: center;
    gap: 12px;
}

.project-icon {
    width: 36px;
    height: 36px;
    min-width: 36px;
    border-radius: 8px;
    background: rgba(67, 97, 238, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
}

.project-icon i {
    font-size: 14px;
}

/* Botones de acción */
.action-buttons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
}

.btn-action {
    width: 32px;
    height: 32px;
    min-width: 32px;
    padding: 0;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    background: white;
    border: 1px solid #e2e8f0;
    transition: all 0.2s ease;
    position: relative;
}

.btn-action:not(.btn-primary) i {
    font-size: 14px;
}

.btn-action:hover {
    background: #f8fafc;
    color: var(--primary);
    border-color: #cbd5e1;
    transform: translateY(-1px);
}

.btn-action.btn-primary {
    background: var(--primary);
    color: white;
    border: none;
    padding: 0 16px;
    gap: 8px;
    width: auto;
}

.btn-action.btn-primary:hover {
    background: #2563eb;
}

.btn-action.btn-primary i {
    font-size: 12px;
}

/* Iconos de las estadísticas */
.stat-icon {
    width: 42px;
    height: 42px;
    min-width: 42px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.stat-icon i {
    font-size: 18px;
}

/* Badges de estado */
.badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 0 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.badge.activo {
    background: #dcfce7;
    color: #15803d;
}

.badge.inactivo {
    background: #f1f5f9;
    color: #475569;
}

.badge.cerrado {
    background: #fee2e2;
    color: #991b1b;
}

/* Dropdown de exportación */
.dropdown-menu {
    min-width: 160px;
    padding: 6px;
    border: none;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    border-radius: 8px;
    margin-top: 4px;
}

.dropdown-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 6px;
    color: #475569;
    font-size: 14px;
    transition: all 0.2s ease;
}

.dropdown-item i {
    font-size: 14px;
    width: 16px;
    text-align: center;
}

.dropdown-item:hover {
    background: #f8fafc;
    color: var(--primary);
}

/* Barra de búsqueda */
.search-container {
    position: relative;
}

.search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 14px;
    pointer-events: none;
}

.search-input {
    padding: 8px 12px 8px 36px;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    font-size: 14px;
    width: 240px;
    transition: all 0.2s ease;
}

.search-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

/* Switch de mostrar inactivos */
.form-switch {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-left: 0;
}

.form-check-input {
    width: 36px;
    height: 20px;
    margin: 0;
    cursor: pointer;
}

.form-check-label {
    font-size: 14px;
    color: #475569;
    cursor: pointer;
    user-select: none;
}